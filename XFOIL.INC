C
C---- XFOIL code global INCLUDE file
C
      LOGICAL TT, FF
c     PARAMETER (IQX=206, IWX=36, ICX=257)
c      PARAMETER (IQX=500, IWX=200 , ICX=257)
      PARAMETER (IQX=800, IWX=800 , ICX=257)
      PARAMETER (IMX=(ICX-1)/4)
      PARAMETER (IZX=IQX+IWX)
      PARAMETER (IVX=(IQX-5)/2 + IWX + 10)
      PARAMETER (NAX=50)
      PARAMETER (TT=.TRUE., FF=.FALSE.)
      LOGICAL*1 FNAME, PNAME, PNAMX, NAME, LABREF
      LOGICAL OK,YES,GREEK,PLOTF,
     &        LGAMU,LQINU,SHARP,LVISC,LALFA,LWAKE,LPOLAR,
     &        LBLINI,LIPAN,LQAIJ,LADIJ,LWDIJ,LCPXX,LQVDES,LQREFL,
     &        LQSPEC,LVCONV,LCPREF,LCLOCK,LPFILE,LPFILX,
     &        LBFLAP,LFLAP,LEIW,LSCINI,LFOREF
      LOGICAL LPLOT,LSYM,LIQSET
      LOGICAL TFORCE
      REAL*8  NX, NY, MASS, MINF
      INTEGER RETYP, AIJPIV
      character*1 VMXBL
      COMPLEX   ZCOLDW, DZTE, CHORDZ, ZC
      COMPLEX   ZC_CN, PIQ, CN, EIW
C
C---- dimension temporary work and storage arrays (EQUIVALENCED below)
      REAL*8 W1(1),W2(1),W3(1),W4(1),W5(1),W6(1),W7(1),W8(1)
      REAL*8 BIJ(IQX,IZX), CIJ(IWX,IQX)
C
      COMMON/NAM/ VERSION,FNAME(32),PNAME(32),PNAMX(32),NAME(32),NLAB
      COMMON/ISE/ CHINL,CHOUT,AINF
      COMMON/MAT/ Q(IQX,IQX),DQ(IQX),
     &            DZDG(IQX),DZDN(IQX),DZDM(IZX),
     &            DQDG(IQX),DQDM(IZX),QTAN1,QTAN2,
     &            Z_QINF,Z_ALFA,Z_QDOF0,Z_QDOF1,Z_QDOF2,Z_QDOF3
      COMMON/VIS/ AIJ(IQX,IQX),DIJ(IZX,IZX)
      COMMON/CPQ/ QINV(IZX),QVIS(IZX),CPI(IZX),CPV(IZX),
     &            QINVU(IZX,2), QINV_A(IZX)
C     Hong added CHDLEN
      COMMON/XYS/ X(IZX),Y(IZX),XP(IZX),YP(IZX),S(IZX),SLE,CHDLEN,
     &            WGAP(IWX),WAKLEN

      COMMON/STG/ SST, SST_GO, SST_GP
      COMMON/PST/ GAM(IQX),GAMU(IQX,2),SIG(IZX)
      COMMON/NXY/ NX(IZX),NY(IZX),APANEL(IZX)
      COMMON/INV/ SSPEC(ICX),QSPEC(ICX),QSPECP(ICX),QGAMM(ICX),
     &            SSPLE,SMAX,IQ1,IQ2,
     &            ALFQSP,CLQSP,CMQSP,
     &            ALFGAM,CLGAM,CMGAM,
     &            QF0(IQX),QF1(IQX),QF2(IQX),QF3(IQX),
     &            QDOF0,QDOF1,QDOF2,QDOF3,CLSPEC
      COMMON/CIR/ AGTE,AG0,QC(ICX),
     &            SCOLD(ICX),XCOLD(ICX),YCOLD(ICX),SCLE,
     &            ZCOLDW(ICX),DZTE,CHORDZ,
     &            DWC,WC(ICX),SC(ICX),ZC(ICX),ZC_CN(ICX,IMX/4),
     &            PIQ(ICX),CN(0:IMX),EIW(ICX,0:IMX),NC,MC,MCT
      COMMON/INF/ ADEG,ARAD,AWAKE,AVISC,CL,CM,CD,CL_ALF,
     &            PSIO,CIRC,COSA,SINA,QINF,
     &            GAMMA,GAMM1,MINF,TKLAM,CPSTAR,QSTAR
      COMMON/REF/ XPREF(IQX),CPREF(IQX),NCPREF,LABREF(32)
      COMMON/TED/ GAMTE,SIGTE,DXTE,DYTE,DSTE,ANTE,ASTE,SHARP
      COMMON/CON/ PI,HOPI,QOPI,DTOR
      COMMON/PAN/ CVPAR,CTERAT,CTRRAT,XSREF1,XSREF2,XPREF1,XPREF2
      COMMON/INTv/Nvis,NB,NSP,NWvis,NPAN,IST,ITMAX,RETYP,AIJPIV(IQX)
      COMMON/PLT/ IDEV,IHARD,SCALE,PFAC,VFAC,CH,
     &            XOFAIR,YOFAIR,FACAIR,CPMAX,CPMIN,CPDEL
      COMMON/LOG/ OK,YES,GREEK,PLOTF,
     &            LGAMU,LQINU,LVISC,LALFA,LWAKE,LPOLAR,
     &            LBLINI,LIPAN,LQAIJ,LADIJ,LWDIJ,LCPXX,LQVDES,LQREFL,
     &            LQSPEC,LVCONV,LCPREF,LCLOCK,LPFILE,LPFILX,LBFLAP,
     &            LFLAP,LEIW,LSCINI,LFOREF
      COMMON/BUF/ XB(2*IQX),YB(2*IQX),
     &            XBP(2*IQX),YBP(2*IQX),SB(2*IQX),SNEW(8*IQX)
      COMMON/FLP/ XBF,YBF,XOF,YOF,HMOM
C
      COMMON/POL/ PADEG(NAX),PCL(NAX),PCD(NAX),PREYBL(NAX),REYBL
     &            PCM(NAX),PXTR(NAX,2),PHMOM(NAX),NPOL
C
      COMMON/BLV/ XSSI(IVX,2),UEDG(IVX,2),UINV(IVX,2),MASS(IVX,2),
     &            THET(IVX,2),DSTR(IVX,2),CTAU(IVX,2),TAU(IVX,2),
     &            VTI(IVX,2),REINF,ACRIT,XTR1(2),XTR(2),XSSITR(2),
     &            UINV_A(IVX,2)
      COMMON/BLI/ IBLTE(2),NBL(2),IPAN(IVX,2),ISYS(IVX,2),NSYS,
     &            ITRAN(2),TFORCE(2)
      COMMON/BLM/ VA(3,2,IZX),VB(3,2,IZX),VDEL(3,2,IZX),
     &            VM(3,IZX,IZX),VZ(3,2)
      COMMON/BLC/ RMSBL,RMXBL,IMXBL,ISMXBL,RLX,VACCEL,VMXBL
C
      COMMON/D02/ LPLOT,LSYM,LIQSET
      COMMON/D12/ XSF,YSF,XOFF,YOFF
      COMMON/D13/ IQNEW(2)
      COMMON/BL_UNDRLX2/ BETA_BL
      
C  
C---- save storage space
      EQUIVALENCE (Q(1,1 ),W1(1)), (Q(1,7 ),W2(1)),
     &            (Q(1,13),W3(1)), (Q(1,19),W4(1)),
     &            (Q(1,25),W5(1)), (Q(1,31),W6(1)),
     &            (Q(1,37),W7(1)), (Q(1,43),W8(1))
      EQUIVALENCE (VM(1,1,1),BIJ(1,1)), (VM(1,1,IZX/2),CIJ(1,1))
